<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_thanh_ly_tai_san_form" model="ir.ui.view">
            <field name="name">thanh_ly_tai_san</field>
            <field name="model">thanh_ly_tai_san</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_duyet" string="Duyệt thanh lý" type="object" attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}" class="oe_highlight"/>
                        <button name="action_tu_choi" string="Từ chối" type="object" attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>
                        <field name="trang_thai" widget="statusbar" statusbar_visible="nhap,da_duyet,tu_choi"/>
                    </header>
                    <sheet>
                        <group col="4">
                            <field name="tai_san_id" domain="[('trang_thai_su_dung', '!=', 'thanh_ly'), ('trang_thai_khau_hao', '!=', 'da_thanh_ly')]"/>
                            <field name="gia_tri_thanh_ly"/>
                            <field name="nguoi_duyet_id"/>
                            <field name="ly_do"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_thanh_ly_tai_san_tree" model="ir.ui.view">
            <field name="name">thanh_ly_tai_san</field>
            <field name="model">thanh_ly_tai_san</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="tai_san_id"/>
                    <field name="gia_tri_thanh_ly"/>
                    <field name="nguoi_duyet_id"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <record id="action_thanh_ly_tai_san" model="ir.actions.act_window">
            <field name="name">Thanh lý tài sản</field>
            <field name="res_model">thanh_ly_tai_san</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
