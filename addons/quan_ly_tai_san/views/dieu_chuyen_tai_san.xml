<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_dieu_chuyen_tai_san_form" model="ir.ui.view">
            <field name="name">dieu_chuyen_tai_san</field>
            <field name="model">dieu_chuyen_tai_san</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group col="4">
                            <field name="tai_san_id" domain="[('trang_thai_su_dung', '!=', 'thanh_ly'), ('trang_thai_khau_hao', '!=', 'da_thanh_ly')]"/>
                            <field name="ngay_dieu_chuyen"/>
                            <field name="nhan_vien_cu_id"/>
                            <field name="phong_ban_cu_id"/>
                            <field name="nhan_vien_moi_id"/>
                            <field name="phong_ban_moi_id" readonly="1" force_save="1"/>
                            <field name="ly_do"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_dieu_chuyen_tai_san_tree" model="ir.ui.view">
            <field name="name">dieu_chuyen_tai_san</field>
            <field name="model">dieu_chuyen_tai_san</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="tai_san_id"/>
                    <field name="ngay_dieu_chuyen"/>
                    <field name="nhan_vien_cu_id"/>
                    <field name="nhan_vien_moi_id"/>
                    <field name="phong_ban_cu_id"/>
                    <field name="phong_ban_moi_id"/>
                </tree>
            </field>
        </record>

        <record id="action_dieu_chuyen_tai_san" model="ir.actions.act_window">
            <field name="name">Điều chuyển tài sản</field>
            <field name="res_model">dieu_chuyen_tai_san</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
