<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_lich_su_khau_hao_form" model="ir.ui.view">
            <field name="name">lich_su_khau_hao</field>
            <field name="model">lich_su_khau_hao</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group col="4">
                            <field name="ho_so_khau_hao_id"/>
                            <field name="thang"/>
                            <field name="so_tien"/>
                            <field name="gia_tri_con_lai"/>
                            <field name="ngay_ghi_nhan"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_lich_su_khau_hao_tree" model="ir.ui.view">
            <field name="name">lich_su_khau_hao</field>
            <field name="model">lich_su_khau_hao</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ho_so_khau_hao_id"/>
                    <field name="thang"/>
                    <field name="so_tien"/>
                    <field name="gia_tri_con_lai"/>
                    <field name="ngay_ghi_nhan"/>
                </tree>
            </field>
        </record>

        <record id="action_lich_su_khau_hao" model="ir.actions.act_window">
            <field name="name">Lịch sử khấu hao</field>
            <field name="res_model">lich_su_khau_hao</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
